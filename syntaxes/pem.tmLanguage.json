{
  "name": "PEM",
  "scopeName": "source.pem",
  "patterns": [
    { "include": "#header" },
    { "include": "#footer" },
    { "include": "#content" }
  ],
  "repository": {
    "header": {
      "name": "keyword.control.pem",
      "match": "^-{5}BEGIN [A-Z ]+-{5}$"
    },
    "footer": {
      "name": "keyword.control.pem",
      "match": "^-{5}END [A-Z ]+-{5}$"
    },
    "content": {
      "name": "string.unquoted.pem",
      "match": "^[A-Za-z0-9+/=]+$"
    }
  }
}
